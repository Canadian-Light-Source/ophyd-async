{
    field(FTVL, "STRING")
    field(NELM, "4096")
    field(INP, {const:["Hello", "World", "Foo", "Bar"]})
    field(PINI, "YES")
    info(Q:group, {
        "$(device)table": {
            "value.a_str": {
                "+type": "plain",
                "+channel": "VAL",
                "+putorder": 4
