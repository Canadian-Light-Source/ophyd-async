record(waveform, "$(device)table:enum")
{
    field(FTVL, "STRING")
    field(NELM, "4096")
    field(INP, {const:["Aaa", "Bbb", "Aaa", "Ccc"]})
    field(PINI, "YES")
    info(Q:group, {
        "$(device)table": {
            "value.a_enum": {
                "+type": "plain",
                "+channel": "VAL",
                "+putorder": 5,
                "+trigger": "*",
            },
            "": {"+type": "meta", "+channel": "VAL"}
        }
    })
}

record(longout, "$(device)ntndarray:ArraySize0_RBV") {
    field(VAL, "3")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)ntndarray":{
            "dimension[0].size":{+channel:"VAL", +type:"plain", +putorder:0}
        }
    })
}

record(longout, "$(device)ntndarray:ArraySize1_RBV") {
    field(VAL, "2")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)ntndarray":{
            "dimension[1].size":{+channel:"VAL", +type:"plain", +putorder:0}
        }
    })
}

record(waveform, "$(device)ntndarray:data")
{
  field(FTVL, "INT64")
  field(NELM, "6")
  field(INP, {const:[0, 0, 0, 0, 0, 0]})
  field(PINI, "YES")
  info(Q:group, {
        "$(device)ntndarray":{
            +id:"epics:nt/NTNDArray:1.0",
            "value":{
                +type:"any",
                +channel:"VAL",
                +trigger:"*",
            },
            "": {+type:"meta", +channel:"SEVR"}
        }
    })
}

# ntndarray/table are QSRV-only virtual PVs (built from the ntndarray:*/
# table:* records above), so they have no single record of their own to
# reopen for PVI. Alias each into the PVI directory via a stringin record
# whose VAL holds its PV name, the same trick PandA uses for its QSRV-only
# SEQ:n:TABLE structure.
record(stringin, "$(device)ntndarray:_pvi_ref") {
    field(VAL, "$(device)ntndarray")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.ntndarray.r": {"+channel": "VAL", "+type": "plain"}
        }
    })
}

record(stringin, "$(device)table:_pvi_ref") {
    field(VAL, "$(device)table")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.table.rw": {"+channel": "VAL", "+type": "plain"}
        }
    })
}


# Remaining EpicsTestPvaDevice-only array fields, keyed by attribute name,
# so EpicsTestPvaDevice(prefix, with_pvi=True) resolves the same signals as
# the statically PvSuffix-declared version.
# int8a is FTVL=CHAR: QSRV's default "CHAR waveform = C-string" conversion
# kicks in for any record that carries a Q:group tag directly (truncating
# the array at the first zero byte), so alias it via a stringin ref instead
# of reopening it in place -- same indirection already used for
# ntndarray/table above.
record(stringin, "$(device)int8a:_pvi_ref") {
    field(VAL, "$(device)int8a")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.int8a.rw": {"+channel": "VAL", "+type": "plain"}
        }
    })
}

record("*", "$(device)uint16a") {
    info(Q:group, {
        "$(device)PVI": {
            "value.uint16a.rw": {"+channel": "NAME", "+type": "plain"}
        }
    })
}

record("*", "$(device)uint32a") {
