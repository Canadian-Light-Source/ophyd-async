# --- Undeclared DeviceVector of devices "extra_devices": served here but
# deliberately not annotated on EpicsTestPviNestedDevice, to prove that
# PviDeviceConnector fills in undeclared DeviceVectors of devices
# dynamically -- mirroring PandA's real ttlout/extra vectors, which are
# also never annotated on the common Panda class. Same three-tier shape
# as "device_vector" above. ---

record(stringin, "$(device)ed:_pvi_ref") {
    field(VAL, "$(device)ed:PVI")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.extra_devices.d": {"+channel": "VAL", "+type": "plain"}
        }
    })
}

