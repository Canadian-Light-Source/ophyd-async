# mbb_direct_bit_r/mbb_direct_bit read/write a single bit (B0) of the
# mbbiDirect/mbboDirect records, not the whole record: NAME self-reference
# only gives the base record name, so alias the exact bit-field PV via a
# stringin ref (same trick used for the QSRV-only ntndarray/table PVs in
# _epics_test_pva_records.db). This mirrors EpicsTestCaDevice/
# EpicsTestPvaDevice's own "mbb_direct_bit_r"/"mbb_direct_bit" fields;
# EpicsTestPviDevice.mbb_direct_bit_r reuses the "value.mbb_direct_bit_r.r"
# entry below directly, no separate PVI structure needed for it.
record(stringin, "$(device)mbb_direct:_pvi_ref") {
    field(VAL, "$(device)mbb_direct.B0")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.mbb_direct_bit_r.r": {"+channel": "VAL", "+type": "plain"}
        }
    })
}

record(stringin, "$(device)mbb_direct_rw:_pvi_ref") {
    field(VAL, "$(device)mbb_direct_rw.B0")
    field(PINI, "YES")
    info(Q:group, {
        "$(device)PVI": {
            "value.mbb_direct_bit.rw": {"+channel": "VAL", "+type": "plain"}
        }
    })
}

# Zero-arg command ("x" PVI entry). Also EpicsTestCaDevice's own "go"
# TriggerableCommand field, same attribute name.
record("*", "$(device)go") {
    info(Q:group, {
        "$(device)PVI": {
            "value.go.x": {"+channel": "NAME", "+type": "plain"}
        }
    })
}
