# PVI directory tags for the generic (non-PandA) PVI test backend, sitting
# directly alongside the records they describe (mirrors how a real EPICS
# C++ IOC generates PVI from QSRV2 directives in the same db, not a
# bolted-on separate file). Reopens each record with the special "*" record
# type so we don't need to know/repeat its real record type. "+channel":
# "NAME" publishes the target record's own PV name as the PVI directory
# string, exactly as PviDeviceConnector expects to then pvget.
#
# Every EpicsTestCaDevice/EpicsTestPvaDevice field also gets a PVI directory
# entry keyed by its *Python attribute name* (not its record name, where
# they differ, e.g. a_int -> "int"), so EpicsTestCaDevice(prefix,
# with_pvi=True) / EpicsTestPvaDevice(prefix, with_pvi=True) resolve to
# exactly the same signals as the statically PvSuffix-declared versions.
#
# wo_float/overridden_float/a_float all resolve to the *same* "float"
# record regardless of PVI key: the r/w/rw designator only affects which
# SignalR/SignalW/SignalRW type the client constructs. overridden_float
# also carries a PvSuffix("float_prec_1") on the Python side, pointing at
# a *different* record: connecting should show the PVI-supplied "float"
# value winning over the statically-configured one. The SignalR-from-PVI
# case is instead demonstrated by EpicsTestPviDevice.mbb_direct_bit_r,
# which reuses EpicsTestCaDevice's own "mbb_direct_bit_r" PVI entry below
# directly rather than a synthetic one on this record.
record("*", "$(device)float") {
    info(Q:group, {
        "$(device)PVI": {
            "value.wo_float.w": {"+channel": "NAME", "+type": "plain"},
            "value.overridden_float.rw": {"+channel": "NAME", "+type": "plain"},
            "value.a_float.rw": {"+channel": "NAME", "+type": "plain"}
        }
    })
}

# extra_int is a PVI entry for a signal that is *not* declared as an
# annotation on EpicsTestPviDevice at all: PviDeviceConnector should still
# add it as a dynamically-discovered child once connected. a_int is
# EpicsTestCaDevice's own declared name for this same record.
record("*", "$(device)int") {
    info(Q:group, {
        "$(device)PVI": {
            "value.extra_int.rw": {"+channel": "NAME", "+type": "plain"},
            "value.a_int.rw": {"+channel": "NAME", "+type": "plain"}
        }
    })
}

record("*", "$(device)float_prec_0") {
    info(Q:group, {
        "$(device)PVI": {
            "value.float_prec_0.rw": {"+channel": "NAME", "+type": "plain"}
        }
    })
}

